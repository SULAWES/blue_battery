<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BlueBattery.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SettingsWindow">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Border
        Padding="18"
        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
        CornerRadius="12">
        <Grid RowDefinitions="Auto,*" RowSpacing="16">
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.StartupSectionTitle, Mode=OneWay}" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12">
                <StackPanel Spacing="12">
                    <ToggleSwitch
                        x:Name="StartupToggleSwitch"
                        Header="{x:Bind ViewModel.StartupToggleHeader, Mode=OneWay}"
                        IsEnabled="{x:Bind ViewModel.CanToggleStartup, Mode=OneWay}"
                        IsOn="{x:Bind ViewModel.StartupEnabled, Mode=OneWay}"
                        Toggled="StartupToggleSwitch_OnToggled" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.StartupToggleDescription, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.StartupStatusText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <Button
                        HorizontalAlignment="Left"
                        Click="OpenSystemStartupSettingsButton_OnClick"
                        Content="{x:Bind ViewModel.OpenSystemStartupSettingsText, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.SystemSettingsActionVisibility, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
