<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BlueBattery.PanelWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BlueBattery.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="blue_battery">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Border
        Padding="20"
        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="16">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="12">
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.AppTitle, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <InfoBar
                Grid.Row="1"
                IsOpen="True"
                IsClosable="False"
                Message="{x:Bind ViewModel.InfoBarMessage, Mode=OneWay}"
                Severity="Informational" />

            <Grid
                Grid.Row="2"
                ColumnSpacing="12"
                ColumnDefinitions="*,*">
                <Border
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.DeviceCountLabel, Mode=OneWay}" />
                        <TextBlock
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.DeviceCountText, Mode=OneWay}" />
                    </StackPanel>
                </Border>
                <Border
                    Grid.Column="1"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.LowestBatteryLabel, Mode=OneWay}" />
                        <TextBlock
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.LowestBatteryText, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="10">
                <TextBlock
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.DeviceSectionTitle, Mode=OneWay}" />

                <Border
                    Grid.Row="1"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}">
                    <StackPanel Spacing="6">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.EmptyStateTitle, Mode=OneWay}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.EmptyStateDescription, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <ScrollViewer
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled"
                    Visibility="{x:Bind ViewModel.DeviceListVisibility, Mode=OneWay}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DeviceBatteryInfo">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="14"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind DisplayName}" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind MetaText}" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind TimestampText}" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Spacing="4">
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                FontSize="24"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind BatteryText}" />
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind FreshnessText}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border
                Grid.Row="4"
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.CurrentStatusLabel, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.ScopeHint, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.LastRefreshText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
