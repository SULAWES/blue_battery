<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BlueBattery.PanelWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BlueBattery.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="blue_battery">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Border
        Padding="16"
        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="18">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="3">
                    <TextBlock
                        FontSize="19"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.AppTitle, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    MinWidth="70"
                    Padding="10,7"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="999">
                    <StackPanel HorizontalAlignment="Center" Spacing="1">
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind ViewModel.DeviceCountLabel, Mode=OneWay}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.DeviceCountText, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid
                Grid.Row="1"
                ColumnSpacing="10"
                ColumnDefinitions="*,*">
                <Border
                    Padding="12,10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <FontIcon
                            VerticalAlignment="Center"
                            FontSize="14"
                            Glyph="&#xE7F4;" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind ViewModel.LowestBatteryLabel, Mode=OneWay}" />
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.LowestBatteryText, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="12,10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12">
                    <StackPanel Spacing="2">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind ViewModel.LastRefreshText, Mode=OneWay}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind ViewModel.ScopeHint, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.DeviceSectionTitle, Mode=OneWay}" />
                    <TextBlock
                        Grid.Column="1"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.CurrentStatusLabel, Mode=OneWay}" />
                </Grid>

                <Border
                    Grid.Row="1"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="14"
                    Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <FontIcon
                            HorizontalAlignment="Center"
                            FontSize="24"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE7F4;" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.EmptyStateTitle, Mode=OneWay}"
                            TextAlignment="Center" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.EmptyStateDescription, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <ScrollViewer
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled"
                    Visibility="{x:Bind ViewModel.DeviceListVisibility, Mode=OneWay}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DeviceBatteryInfo">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="12"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Spacing="3">
                                            <TextBlock
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind DisplayName}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind MetaText}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind TimestampText}" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Spacing="3">
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind BatteryText}" />
                                            <Border
                                                HorizontalAlignment="Right"
                                                Padding="8,3"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                CornerRadius="999">
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="{x:Bind FreshnessText}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border
                Grid.Row="3"
                Padding="12,10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Grid.Column="1"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.LastRefreshText, Mode=OneWay}"
                        VerticalAlignment="Bottom" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
