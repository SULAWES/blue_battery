<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BlueBattery.PanelWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="blue_battery">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="20">
        <StackPanel Spacing="12">
            <TextBlock
                FontSize="22"
                FontWeight="SemiBold"
                Text="blue_battery" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="独立轻量面板已接通。当前先承载托盘壳层与占位状态。"
                TextWrapping="WrapWholeWords" />
            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Message="当前面板支持：左键切换、失焦自动关闭、贴靠托盘图标弹出、右键菜单命令分发。"
                Severity="Informational" />
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12">
                <StackPanel Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="当前状态" />
                    <TextBlock Text="暂无设备数据，后续将接入蓝牙读取与设备列表。" TextWrapping="WrapWholeWords" />
                    <TextBlock x:ConnectionId='2'
                        x:Name="ActionStatusTextBlock"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="尚未执行占位操作。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>

